# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=zomato

# ─── API (Go backend) ──────────────────────────────────────────────────────────
APP_PORT=8081
DB_HOST=postgres        # matches the docker-compose service name
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=zomato
JWT_SECRET=change_me_in_production

# ─── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8081
